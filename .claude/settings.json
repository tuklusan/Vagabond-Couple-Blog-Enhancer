{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__*"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude\\autocommit_and_push.py",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "Auto-committing before test/run..."
          },
          {
            "type": "command",
            "command": "python .claude\\check_no_background.py",
            "shell": "powershell",
            "timeout": 5,
            "statusMessage": "Checking for banned background task..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude\\check_no_direct_python_write.py",
            "shell": "powershell",
            "timeout": 5,
            "statusMessage": "Enforcing coder workflow..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude\\autocommit_and_push.py",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "Auto-committing before review..."
          },
          {
            "type": "command",
            "command": "python .claude\\deepseek_review_hook.py",
            "shell": "powershell",
            "timeout": 60,
            "statusMessage": "DeepSeek reviewing changes..."
          }
        ]
      }
    ]
  }
}
