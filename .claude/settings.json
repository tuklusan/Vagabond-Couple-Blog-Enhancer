{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__*"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude\\check_no_background.py",
            "shell": "powershell",
            "timeout": 5,
            "statusMessage": "Enforcing no-background-task rule..."
          },
          {
            "type": "command",
            "command": "python .claude\\commit_push_rule.py --phase pre",
            "shell": "powershell",
            "timeout": 180,
            "statusMessage": "Commit+push rule: checkpoint before review..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude\\check_no_direct_python_write.py",
            "shell": "powershell",
            "timeout": 5,
            "statusMessage": "Enforcing coder workflow..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude\\commit_push_rule.py --phase post",
            "shell": "powershell",
            "timeout": 180,
            "statusMessage": "Commit+push rule: checkpoint after ticket close..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude\\check_and_update_docs.py",
            "shell": "powershell",
            "timeout": 60,
            "statusMessage": "Checking if docs need updating..."
          }
        ]
      }
    ]
  }
}
